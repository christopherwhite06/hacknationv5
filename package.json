{
  "name": "city-wallet-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:phone": "powershell -ExecutionPolicy Bypass -File scripts/run-android.ps1",
    "api": "node server/dev-api.js",
    "emulator": "powershell -ExecutionPolicy Bypass -File scripts/start-android-emulator.ps1",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "smoke:api": "node scripts/smoke-city-wallet-api.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "latest",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-location": "^55.1.8",
    "expo-speech": "~55.0.13",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-maps": "1.27.2",
    "react-native-qrcode-svg": "latest",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "babel-preset-expo": "^55.0.18",
    "typescript": "latest"
  }
}
