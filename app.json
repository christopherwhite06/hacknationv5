{
  "expo": {
    "name": "Spark City Wallet",
    "slug": "spark-city-wallet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/final_logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sparkcitywallet",
    "splash": {
      "image": "./assets/ChatGPT Image Apr 25, 2026, 10_59_28 PM.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/final_logo.png",
        "backgroundColor": "#FFE1F0"
      },
      "package": "com.sparkcitywallet.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spark uses your position to center the map and find nearby offers."
        }
      ]
    ]
  }
}
